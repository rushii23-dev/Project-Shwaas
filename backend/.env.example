# Copy this file to .env and fill in real keys. The app fails loudly (HTTP 503
# with a clear message) on any endpoint that needs a key you haven't set --
# it never silently substitutes fake data.

# Primary live AQI source (Delhi ground stations). Free token:
# https://aqicn.org/data-platform/token/
WAQI_TOKEN=

# Free instant MAP_KEY: https://firms.modaps.eosdis.nasa.gov/api/map_key/
FIRMS_MAP_KEY=

# Free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional
CORS_ORIGINS=http://localhost:5173
